    function runTerminalSimulation() {
        document.getElementById('screen-loading').style.display = 'none';
        document.getElementById('screen-terminal').style.display = 'block';
        
        const input = document.getElementById('main-search-input').value.trim();
        const output = document.getElementById('terminal-output');
        
        // Очищаем ввод от всего, кроме цифр
        const cleanInput = input.replace(/\D/g, '');
        
        // Ищем в базе: перебираем каждое поле каждого объекта
        const found = fullDatabase.find(item => {
            return Object.values(item).some(val => {
                const dbValue = String(val).replace(/\D/g, '');
                // Сравниваем очищенные строки (если это цифры)
                if (cleanInput.length > 0 && dbValue.length > 0) {
                    return dbValue.includes(cleanInput);
                }
                // Иначе ищем по точному текстовому совпадению
                return String(val).toLowerCase() === input.toLowerCase();
            });
        });
        
        if (found) {
            let resultHtml = `[+] ДАННЫЕ НАЙДЕНЫ:<br>`;
            for (let key in found) {
                resultHtml += `• ${key}: ${found[key]}<br>`;
            }
            output.innerHTML = resultHtml;
        } else {
            output.innerHTML = `[-] Совпадений по запросу "${input}" не найдено.`;
        }
        document.getElementById('btn-restart').style.display = 'block';
    }
